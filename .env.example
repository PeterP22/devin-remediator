# Devin v3 API — Member-role service user (Settings > Devin API > Service users)
DEVIN_API_KEY=cog_your_service_user_key
DEVIN_ORG_ID=org-your_org_id

# GitHub — token with repo scope on the fork; used for issues/comments
GITHUB_TOKEN=ghp_your_token
GITHUB_REPO=YourUser/superset

# Webhook shared secret (same value configured on the GitHub webhook)
WEBHOOK_SECRET=generate_a_long_random_string

# Tuning
MAX_ACU_LIMIT=15
POLL_INTERVAL_SECONDS=60
